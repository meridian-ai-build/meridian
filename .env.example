# ── Supabase ──────────────────────────────────────────────────────────────────
# Settings → API in your Supabase project dashboard
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here  # NEVER expose to client

# ── Stripe ────────────────────────────────────────────────────────────────────
# Developers → API keys in your Stripe dashboard
STRIPE_SECRET_KEY=sk_live_...          # or sk_test_... for testing
STRIPE_WEBHOOK_SECRET=whsec_...        # from Stripe → Webhooks → your endpoint

# ── App ───────────────────────────────────────────────────────────────────────
# Your production URL (used for Stripe redirect URLs)
APP_URL=https://your-app.vercel.app
